[
  {
    "title": "年輪",
    "stanzas": [
      { "lines": ["歲月在木里", "雕入了四季", "一圈又一圈", "是綿長的線"] },
      { "lines": ["歲月在池裡", "刻入了六欲", "一層又一層", "是擴散的圓"], "indent": true },
      { "lines": ["歲月在心裡", "放入了你我", "一日又一日", "是不盡的思念"] }
    ]
  },
  {
    "title": "不再",
    "stanzas": [
      { "lines": ["我是無夜的光　想擁你入懷中", "可你不屬於我　我也從未擁有"] },
      { "lines": ["流光劃過　是我悲傷的淚", "時隔七年　無聲之雨終落", "火樹銀花　星沉大海", "僅此一次　為你燦爛"] },
      { "lines": ["我是黎明的夜　飲下晨露", "忘卻那陣清風　昂首闊步", "你是你　我是我　天涯各一路", "道別"] }
    ]
  },
  {
    "title": "雪城",
    "stanzas": [
      { "lines": ["滿天晶晶　　一層層凍下", "一點一滴　　蠶食著巍峨"] },
      { "lines": ["巍峨的聖城　　守護著生機", "輝煌的天光　　孕養著枝芽", "七彩的虹湖　　滋潤著情根", "流轉的日月　　刻劃著從前"] },
      { "lines": ["花開七輪　　葉漸黃", "三生樹下斷人腸", "無春　　無夏　　無秋", "唯有斑駁　　殘落　　冰封"] },
      { "lines": ["三千世界遇寒冬", "心不受", "相思雪盡沒"] }
    ]
  }
